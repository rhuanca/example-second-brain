# Copy to .env and fill in. .env is gitignored.
#   cp env.example .env

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id (the only user the bot serves).
# Get it by messaging @userinfobot.
TELEGRAM_ALLOWED_USER_ID=

# Claude API key (provided later). Tests mock the LLM, so this can stay empty
# during development.
ANTHROPIC_API_KEY=

# Claude model to use for summaries.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Supadata API key for YouTube transcripts (https://supadata.ai).
# When set, transcripts are fetched via Supadata's servers, which avoids the
# YouTube IP block that hits the local library on cloud/VPS hosts. Empty = use
# the local youtube-transcript-api.
SUPADATA_API_KEY=

# Web article extraction via Jina Reader (https://jina.ai/reader), which converts
# a page to Markdown AND captions its images with a vision model — so diagrams get
# summarized too. The caption feature requires a key (free at jina.ai). Without a
# key, articles fall back to local trafilatura (text only, no captions).
JINA_API_KEY=
# Set to false to disable Jina entirely and always use trafilatura.
JINA_ENABLED=true

# Absolute path to the dedicated Obsidian vault. PARA folders are created here.
VAULT_PATH=./vault

# --- Slack (optional) — the desk-side "ask" bot; capture stays on Telegram ---
# Only needed if you run the Slack bot (python -m second_brain.slack_main).
# See the README "Slack" section for how to create the app + get these.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USER_ID=

# Optional: your Medium session cookie, to summarize member-only articles you pay
# for. Value = the `sid` cookie from medium.com (browser DevTools > Application >
# Cookies > medium.com > sid). Leave empty to only get free-post/teaser content.
MEDIUM_COOKIE=
